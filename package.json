{
	"name": "planner",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:dependencies": "node --test scripts/audit-dependencies.test.mjs",
		"test:migrations": "node --test scripts/migration-quality.test.mjs",
		"lint": "eslint \"src/**/*.{js,ts,svelte}\" \"scripts/*.mjs\"",
		"format:check": "prettier --check \"src/**/*.{js,ts,svelte}\" \"scripts/**/*.{mjs,json}\" \"*.{js,ts,json,md,yml,yaml}\" \".github/**/*.{yml,yaml}\" \"security/**/*.json\"",
		"lint:complexity": "npm run lint",
		"quality:duplication": "node scripts/check-duplication.mjs",
		"quality:dependencies": "node scripts/audit-dependencies.mjs",
		"quality:migrations": "node scripts/check-migrations.mjs",
		"quality:immutability": "node scripts/check-migration-immutability.mjs",
		"quality": "npm run check && npm run lint && npm run format:check && npm run test:coverage && npm run quality:duplication && npm run quality:migrations",
		"test:mutation": "stryker run && node scripts/check-mutation-modules.mjs",
		"test:mutation:modules": "node scripts/check-mutation-modules.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:rls": "supabase test db",
		"quality:deadcode": "knip --no-exit-code"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/d3-hierarchy": "^3.1.7",
		"@types/d3-scale": "^4.0.9",
		"@vitest/coverage-v8": "^4.1.6",
		"eslint": "^10.7.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.3.0",
		"jscpd": "^5.0.12",
		"knip": "^6.26.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"supabase": "^2.109.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.105.1",
		"@types/papaparse": "^5.5.2",
		"layerchart": "^1.0.13",
		"lucide-svelte": "^1.0.1",
		"papaparse": "^5.5.3",
		"zod": "^4.4.2"
	}
}
