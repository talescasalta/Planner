# Supabase
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=

# OpenAI / OpenRouter (server-side only)
# If OPENROUTER_API_KEY is set, OpenRouter is used; otherwise OpenAI.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Model id sent to the chosen provider. For OpenRouter use the slug
# (e.g. "openai/gpt-4o-mini", "anthropic/claude-3.5-sonnet",
# "google/gemini-2.0-flash-001", "xiaomi/mimo-v2.5-pro").
# For OpenAI use the bare id (e.g. "gpt-4o-mini").
LLM_MODEL=
